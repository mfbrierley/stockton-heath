{
  "expo": {
    "name": "stockton-heath",
    "slug": "stockton-heath",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sh-icon.png",
    "scheme": "stocktonheath",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattbrierley1.stocktonheath",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sh-icon.png",
        "backgroundColor": "#1B4332"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/sh-icon.png",
          "color": "#ffffff",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "99721d3f-5cda-481a-bf9d-f4a170ea4c95"
      }
    },
    "owner": "mattbrierley1"
  }
}
